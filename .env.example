# TruBot AI - Configuration
# Copy this to .env and update values

# =============================================
# LLM Configuration
# =============================================
# Mode: "mock" (no API key needed), "groq" (recommended), or "openai"
LLM_MODE=groq

# Groq API Key (get free key at https://console.groq.com)
GROQ_API_KEY=gsk_your-groq-key-here

# Model to use
# Groq: llama-3.3-70b-versatile, llama-3.1-8b-instant, mixtral-8x7b-32768
# OpenAI: gpt-4o-mini, gpt-4o
LLM_MODEL=llama-3.3-70b-versatile

# =============================================
# Gmail SMTP (for Send Real Email feature)
# =============================================
# Step 1: Enable 2FA on your Google account
# Step 2: Go to https://myaccount.google.com/apppasswords
# Step 3: Create App Password → name it "TruBot AI"
# Step 4: Paste the 16-char password below (no spaces)

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-gmail@gmail.com
SMTP_PASS=abcdefghijklmnop

# Email mode for bulk campaigns: "mock" (simulated) or "smtp" (real)
# Note: "Send Real Email" button always uses SMTP regardless of this setting
EMAIL_MODE=mock
